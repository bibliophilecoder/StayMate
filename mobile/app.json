{
  "expo": {
    "name": "StayMate",
    "slug": "staymate",
    "scheme": "staymate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "StayMate uses your photos for your roommate profile."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#5267E8"
        }
      ]
    ],
    "android": {
      "package": "com.staymate.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#F7FAFC"
      },
      "blockedPermissions": ["android.permission.RECORD_AUDIO"]
    },
    "ios": {
      "bundleIdentifier": "com.staymate.app",
      "supportsTablet": true
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "581fcddb-4ff8-4556-8316-2e7475e65a80"
      }
    },
    "owner": "riyapalod"
  }
}
